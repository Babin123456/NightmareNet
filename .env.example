# -----------------------------------------------------------------------------
# NightmareNet Backend & Infrastructure Environment Variables
# Copy this file to .env before running the project.
# Update the values as needed for your local environment.
# -----------------------------------------------------------------------------

# Allowed CORS origins.
NIGHTMARENET_CORS_ORIGINS=*


# Logging level.
NIGHTMARENET_LOG_LEVEL=info


# API authentication key.
# Leave empty for local development if authentication is disabled.
NIGHTMARENET_API_KEY=your-api-key


# PostgreSQL database name.
POSTGRES_DB=nightmarenet


# PostgreSQL username.
POSTGRES_USER=nightmare


# PostgreSQL password.
POSTGRES_PASSWORD=nightmare


# PostgreSQL port.
POSTGRES_PORT=5432


# Redis port.
REDIS_PORT=6379


# Database connection URL.
NIGHTMARENET_DATABASE_URL=postgresql+psycopg://nightmare:nightmare@db:5432/nightmarenet


# Redis connection URL.
NIGHTMARENET_REDIS_URL=redis://redis:6379/0


# API server port.
API_PORT=8000


# Celery worker concurrency.
CELERY_CONCURRENCY=2


# Celery log level.
CELERY_LOGLEVEL=info


# Frontend development port.
FRONTEND_PORT=3000
